<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Settings – VisionAI</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="dash-layout">

  <%- include('partials/sidebar', { active: 'settings' }) %>

  <main class="dash-main">
    <div class="dash-header">
      <h1>Settings</h1>
      <p>Manage your account and application preferences.</p>
    </div>

    <!-- Profile -->
    <div class="settings-section">
      <h3>👤 Profile</h3>
      <div class="settings-row">
        <div>
          <label>Username</label>
          <p>Your display name across the platform</p>
        </div>
        <span style="color:var(--secondary);font-weight:600"><%= user.username %></span>
      </div>
      <div class="settings-row">
        <div>
          <label>Role</label>
          <p>Your permission level</p>
        </div>
        <span class="badge badge-active">Admin</span>
      </div>
      <div class="settings-row">
        <div>
          <label>Agency</label>
          <p>Your organisation</p>
        </div>
        <span style="color:var(--muted)">VisionAI Marketing</span>
      </div>
    </div>

    <!-- Notifications -->
    <div class="settings-section">
      <h3>🔔 Notifications</h3>
      <div class="settings-row">
        <div>
          <label>Email Alerts</label>
          <p>Receive weekly performance summaries</p>
        </div>
        <div class="toggle on" onclick="this.classList.toggle('on')"></div>
      </div>
      <div class="settings-row">
        <div>
          <label>New Contact Alerts</label>
          <p>Notify when a new contact is added</p>
        </div>
        <div class="toggle on" onclick="this.classList.toggle('on')"></div>
      </div>
      <div class="settings-row">
        <div>
          <label>Campaign Reports</label>
          <p>Monthly AI campaign summaries</p>
        </div>
        <div class="toggle" onclick="this.classList.toggle('on')"></div>
      </div>
    </div>

    <!-- Integrations -->
    <div class="settings-section">
      <h3>🔗 Integrations</h3>
      <div class="settings-row">
        <div>
          <label>Google Analytics</label>
          <p>Sync traffic data automatically</p>
        </div>
        <span class="badge badge-active">Connected</span>
      </div>
      <div class="settings-row">
        <div>
          <label>Mailchimp</label>
          <p>Sync contacts with your email lists</p>
        </div>
        <span class="badge badge-inactive">Disconnected</span>
      </div>
      <div class="settings-row">
        <div>
          <label>OpenAI API</label>
          <p>Power AI content and automation</p>
        </div>
        <span class="badge badge-active">Connected</span>
      </div>
    </div>

    <!-- Danger Zone -->
    <div class="settings-section" style="border-color:rgba(248,113,113,.2)">
      <h3 style="color:var(--danger)">⚠️ Danger Zone</h3>
      <div class="settings-row">
        <div>
          <label>Export Data</label>
          <p>Download all your contacts and analytics</p>
        </div>
        <button class="btn btn-ghost btn-sm">Export CSV</button>
      </div>
      <div class="settings-row">
        <div>
          <label>Sign Out Everywhere</label>
          <p>Terminate all active sessions</p>
        </div>
        <a href="/logout" class="btn btn-sm" style="background:rgba(248,113,113,.15);color:var(--danger)">Logout All</a>
      </div>
    </div>
  </main>
</div>
</body>
</html>
