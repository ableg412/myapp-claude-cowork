<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Analytics – VisionAI</title>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
<div class="dash-layout">

  <%- include('partials/sidebar', { active: 'analytics' }) %>

  <main class="dash-main">
    <div class="dash-header">
      <h1>Analytics</h1>
      <p>Track performance and uncover growth opportunities.</p>
    </div>

    <!-- Summary Stats -->
    <div class="stats-grid" style="margin-bottom:32px">
      <div class="stat-card">
        <div class="stat-label">Total Visits</div>
        <div class="stat-value gradient-text">48,210</div>
        <div class="stat-delta">↑ 22% vs last month</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Conversion Rate</div>
        <div class="stat-value gradient-text">4.7%</div>
        <div class="stat-delta">↑ 0.9% vs last month</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Avg. Session</div>
        <div class="stat-value gradient-text">3:24</div>
        <div class="stat-delta">↑ 14s vs last month</div>
      </div>
      <div class="stat-card">
        <div class="stat-label">Bounce Rate</div>
        <div class="stat-value gradient-text">28%</div>
        <div class="stat-delta">↓ 5% improvement</div>
      </div>
    </div>

    <div class="analytics-grid">
      <!-- Bar Chart -->
      <div class="chart-placeholder">
        <h3>Monthly Traffic</h3>
        <div class="bar-chart">
          <div class="bar" style="height:55%;background:linear-gradient(to top,#6c63ff,#a78bfa)"></div>
          <div class="bar" style="height:70%;background:linear-gradient(to top,#6c63ff,#a78bfa)"></div>
          <div class="bar" style="height:45%;background:linear-gradient(to top,#6c63ff,#a78bfa)"></div>
          <div class="bar" style="height:80%;background:linear-gradient(to top,#6c63ff,#a78bfa)"></div>
          <div class="bar" style="height:65%;background:linear-gradient(to top,#6c63ff,#a78bfa)"></div>
          <div class="bar" style="height:90%;background:linear-gradient(to top,#6c63ff,#f472b6)"></div>
          <div class="bar" style="height:75%;background:linear-gradient(to top,#6c63ff,#a78bfa)"></div>
        </div>
        <div class="bar-labels">
          <span>Oct</span><span>Nov</span><span>Dec</span>
          <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span>
        </div>
      </div>

      <!-- Donut Legend -->
      <div class="chart-placeholder">
        <h3>Traffic Sources</h3>
        <div class="donut-wrap">
          <svg width="120" height="120" viewBox="0 0 42 42">
            <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="#6c63ff" stroke-width="6" stroke-dasharray="45 55" stroke-dashoffset="25"/>
            <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="#f472b6" stroke-width="6" stroke-dasharray="25 75" stroke-dashoffset="-20"/>
            <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="#34d399" stroke-width="6" stroke-dasharray="20 80" stroke-dashoffset="-45"/>
            <circle cx="21" cy="21" r="15.915" fill="transparent" stroke="#fbbf24" stroke-width="6" stroke-dasharray="10 90" stroke-dashoffset="-65"/>
          </svg>
          <div class="donut-legend">
            <div class="donut-legend-item"><div class="dot" style="background:#6c63ff"></div>Organic — 45%</div>
            <div class="donut-legend-item"><div class="dot" style="background:#f472b6"></div>Paid Ads — 25%</div>
            <div class="donut-legend-item"><div class="dot" style="background:#34d399"></div>Referral — 20%</div>
            <div class="donut-legend-item"><div class="dot" style="background:#fbbf24"></div>Direct — 10%</div>
          </div>
        </div>
      </div>

      <!-- Revenue Chart -->
      <div class="chart-placeholder">
        <h3>Revenue Growth</h3>
        <div class="bar-chart">
          <div class="bar" style="height:40%;background:linear-gradient(to top,#34d399,#6ee7b7)"></div>
          <div class="bar" style="height:55%;background:linear-gradient(to top,#34d399,#6ee7b7)"></div>
          <div class="bar" style="height:60%;background:linear-gradient(to top,#34d399,#6ee7b7)"></div>
          <div class="bar" style="height:70%;background:linear-gradient(to top,#34d399,#6ee7b7)"></div>
          <div class="bar" style="height:75%;background:linear-gradient(to top,#34d399,#6ee7b7)"></div>
          <div class="bar" style="height:88%;background:linear-gradient(to top,#34d399,#f472b6)"></div>
          <div class="bar" style="height:95%;background:linear-gradient(to top,#34d399,#6ee7b7)"></div>
        </div>
        <div class="bar-labels">
          <span>Oct</span><span>Nov</span><span>Dec</span>
          <span>Jan</span><span>Feb</span><span>Mar</span><span>Apr</span>
        </div>
      </div>

      <!-- Top Pages -->
      <div class="chart-placeholder">
        <h3>Top Pages</h3>
        <table style="width:100%">
          <thead>
            <tr>
              <th style="text-align:left;font-size:.75rem;color:var(--muted);padding:6px 0">Page</th>
              <th style="text-align:right;font-size:.75rem;color:var(--muted);padding:6px 0">Views</th>
            </tr>
          </thead>
          <tbody>
            <% [
              ['/','Home','18,240'],
              ['/services','Services','9,110'],
              ['/about','About','6,450'],
              ['/contact','Contact','4,800'],
              ['/blog','Blog','3,290']
            ].forEach(([,page,views]) => { %>
            <tr>
              <td style="padding:10px 0;font-size:.875rem;border-bottom:1px solid rgba(255,255,255,.04)"><%= page %></td>
              <td style="padding:10px 0;font-size:.875rem;text-align:right;color:var(--secondary);border-bottom:1px solid rgba(255,255,255,.04)"><%= views %></td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </main>
</div>
</body>
</html>
